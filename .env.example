# DrWEEE Flow v2.0 — Environment Variables
# Copy this file to .env and fill in your values

# Google Sheets Sync (paste your Google Apps Script Web App URL here)
VITE_SHEETS_WEBHOOK_URL=

# Gemini AI API Key (for AI Assistant page)
VITE_GEMINI_API_KEY=

# ─── EmailJS (Admin → New User Credentials Email) ───────────────────────────
# Sign up free at https://www.emailjs.com
# 1. Create a service (Gmail, Outlook, etc.)
# 2. Create an email template with these variables:
#    {{to_email}}, {{to_name}}, {{employee_id}}, {{user_role}}, {{site_url}}, {{message}}
# 3. Paste your IDs below:
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# If left empty, the system will fall back to opening your default email client (mailto:)
